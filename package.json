{
  "name": "joy-browser",
  "productName": "Joy Browser",
  "version": "0.0.1",
  "description": "A custom Electron-based web browser for Linux",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.joybrowser.app",
    "productName": "Joy Browser",
    "linux": {
      "target": ["AppImage", "tar.gz"],
      "category": "Network",
      "icon": "icon.png",
      "description": "A custom Electron-based web browser for Linux",
      "maintainer": "your-name <your@email.com>"
    },
    "files": [
      "src/**/*",
      "index.html",
      "icon.png",
      "package.json"
    ]
  }
}
